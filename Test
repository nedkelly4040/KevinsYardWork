<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Modern Business Landing Page</title>
    <!-- Tailwind CSS for rapid, modern styling -->
    <script src="https://cdn.tailwindcss.com"></script>
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    colors: {
                        brand: {
                            light: '#3b82f6',
                            DEFAULT: '#1d4ed8',
                            dark: '#1e3a8a',
                        }
                    }
                }
            }
        }
    </script>
</head>
<body class="bg-slate-50 text-slate-800 antialiased min-h-screen flex flex-col">

    <!-- Navigation Header -->
    <header class="bg-white border-b border-slate-100 sticky top-0 z-50">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
            <div class="flex items-center gap-2">
                <span class="text-2xl font-bold text-brand">BizCraft</span>
            </div>
            <nav class="hidden md:flex items-center gap-8 font-medium">
                <a href="#features" class="hover:text-brand transition">Features</a>
                <a href="#services" class="hover:text-brand transition">Services</a>
                <a href="#contact" class="hover:text-brand transition font-semibold text-white bg-brand px-4 py-2 rounded-lg hover:bg-brand-dark">Get Started</a>
            </nav>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="flex-grow">
        <!-- Hero Section -->
        <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 text-center">
            <h1 class="text-4xl sm:text-6xl font-black tracking-tight text-slate-900 mb-6">
                Build Premium Websites for <span class="text-brand">Your Business</span>
            </h1>
            <p class="text-lg sm:text-xl text-slate-600 max-w-2xl mx-auto mb-8">
                This is a boilerplate template. Use Qwen Code to customize the layout, add interactive sections, and hook up your business logic.
            </p>
            <div class="flex justify-center gap-4">
                <a href="#contact" class="px-6 py-3 font-semibold text-white bg-brand rounded-lg shadow-lg hover:bg-brand-dark transition">
                    Our Services
                </a>
                <a href="#features" class="px-6 py-3 font-semibold text-slate-700 bg-white border border-slate-200 rounded-lg shadow-sm hover:bg-slate-50 transition">
                    Learn More
                </a>
            </div>
        </section>
    </main>

    <!-- Footer -->
    <footer class="bg-slate-900 text-slate-400 py-12">
        <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm">
            <p>&copy; 2026 BizCraft. All rights reserved.</p>
        </div>
    </footer>

</body>
</html>
